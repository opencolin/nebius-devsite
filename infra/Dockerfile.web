# Multi-stage build for the Next.js Pages Router app (apps/web).
# Output: a minimal runtime image hosting the standalone server.
#
# In prod this runs in Azure Container Apps behind Azure Front Door — the same
# x-azure-ref topology you can see on a `curl -I https://nebius.com`.

# ---- builder ----------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Workspace files first, for cache-friendly installs
COPY apps/web/package.json apps/web/package-lock.json* ./apps/web/
RUN cd apps/web && npm ci --no-audit --no-fund

# Now the source
COPY apps/web ./apps/web

# Build env (Next reads NEXT_PUBLIC_* into the bundle at build time)
ARG NEXT_PUBLIC_DIRECTUS_PUBLIC_URL
ARG NEXT_PUBLIC_GTM_ID
ARG NEXT_PUBLIC_GTM_PROXY

# Server-side DIRECTUS_URL — needed by getStaticProps / getStaticPaths to
# enumerate slugs and render content at build time. The Container App's
# runtime DIRECTUS_URL env var still wins for live requests.
ARG DIRECTUS_URL

ENV NEXT_PUBLIC_DIRECTUS_PUBLIC_URL=$NEXT_PUBLIC_DIRECTUS_PUBLIC_URL \
    NEXT_PUBLIC_GTM_ID=$NEXT_PUBLIC_GTM_ID \
    NEXT_PUBLIC_GTM_PROXY=$NEXT_PUBLIC_GTM_PROXY \
    DIRECTUS_URL=$DIRECTUS_URL

ENV BUILD_STANDALONE=1

# DIRECTUS_ADMIN_TOKEN comes in as a BuildKit secret (not ARG/ENV — those bake
# the token into image metadata, which Docker rightly flags as SecretsUsedInArgOrEnv).
# The secret is mounted at /run/secrets/directus_admin_token for the duration
# of this single RUN, exported into the env so Next's getStaticProps can use it,
# then disappears with the layer. required=false lets local dev builds work
# without the token (the build will succeed but skip pages that need Directus).
RUN --mount=type=secret,id=directus_admin_token,required=false \
    if [ -s /run/secrets/directus_admin_token ]; then \
      export DIRECTUS_ADMIN_TOKEN="$(cat /run/secrets/directus_admin_token)"; \
    fi && \
    cd apps/web && npm run build

# ---- runner -----------------------------------------------------------------
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Run as non-root
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

# Copy standalone build. Next's standalone output for a single-app project
# rooted at apps/web puts server.js at the standalone root (not under
# apps/web/), so COPY targets resolve flat at /app/. Verified by
# `find /app -name server.js` inside the resulting image: it's /app/server.js.
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./public

USER nextjs
EXPOSE 3000

CMD ["node", "server.js"]
