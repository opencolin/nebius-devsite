# ============================================================================
# Web app (apps/web/.env.local) — Next.js will load these.
# ============================================================================

# Server-side Directus URL (web container → directus container in compose; localhost from your host)
DIRECTUS_URL=http://localhost:8055

# Server-only admin token used for build-time data fetching in [[...slug]].tsx
# Create in Directus admin → Settings → Access Tokens. Static; never shipped to browser.
DIRECTUS_ADMIN_TOKEN=replace-me-with-static-token

# Public Directus URL the *browser* uses for assets (e.g. https://assets.your-domain.com)
NEXT_PUBLIC_DIRECTUS_PUBLIC_URL=http://localhost:8055

# Tavily (used by /api/events/refresh to scrape luma + nebius.com)
# Get a key at https://tavily.com — free tier is fine for refresh use.
TAVILY_API_KEY=

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_ADMIN_KEY=xyz-typesense-admin-key
TYPESENSE_SEARCH_KEY=xyz-typesense-search-only-key

# GTM (leave blank locally to disable; set per-env in prod)
NEXT_PUBLIC_GTM_ID=
# Optional Stape sGTM proxy origin (mirrors gw.stape.run on nebius.com)
NEXT_PUBLIC_GTM_PROXY=

# Auth cookie config
AUTH_COOKIE_NAME=nb_session
AUTH_COOKIE_DOMAIN=
# 1 = require Secure cookie (set 1 in prod, 0 locally)
AUTH_COOKIE_SECURE=0

# ============================================================================
# Directus container (infra/docker-compose.yml)
# ============================================================================

DIRECTUS_KEY=replace-with-uuid
DIRECTUS_SECRET=replace-with-long-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=changeme
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus

# ============================================================================
# Production-only (Azure)
# ============================================================================
# Populated by `az deployment sub create -f infra/azure/main.bicep` outputs.
# AZURE_FRONT_DOOR_ENDPOINT=
# AZURE_CONTAINER_APP_WEB_URL=
# AZURE_CONTAINER_APP_DIRECTUS_URL=
